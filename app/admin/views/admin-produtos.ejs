<!DOCTYPE html>
<html lang="pt-BR">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>adm</title>
  <link rel="stylesheet" href="/css/style.css">
  <link rel="stylesheet" href="/css/header.css">
  <link rel="stylesheet" href="/css/admin.css">
    <link rel="icon" href="/imagens/favicon2.png" type="image/png">
</head>

<section class="admin-wrapper">
  <aside class="admin-sidebar">
    <header class="admin-brand">
      <h2>⚙️ ADMIN</h2>
    </header>
    
    <nav class="admin-nav">
      <a href="/admin" class="nav-item">
        📊 Dashboard
      </a>
      <a href="/admin/usuarios" class="nav-item">
        👥 Usuários
      </a>
      <a href="/admin/diagnosticos" class="nav-item">
        📋 Diagnósticos
      </a>
      <a href="/admin/produtos" class="nav-item active">
        📦 Produtos
      </a>
      <a href="/admin-logout" class="nav-item nav-logout">
        🚪 Sair
      </a>
    </nav>
  </aside>
  
  <main class="admin-main">
    <header class="admin-header">
      <h1>📦 Catálogo de Produtos</h1>
      <p>Total de produtos: <strong><%= produtos.length %></strong></p>
      <a href="/admin/produtos/novo" class="btn btn-primary" style="float: right;">
        ➕ Novo Produto
      </a>
    </div>
    
    <% if (produtos.length > 0) { %>
      <section class="table-container">
        <table class="admin-table">
          <thead>
            <tr>
              <th>ID</th>
              <th>Nome</th>
              <th>Categoria</th>
              <th>Preço</th>
              <th>Estoque</th>
              <th>Ações</th>
            </tr>
          </thead>
          <tbody>
            <% produtos.forEach(produto => { %>
              <tr class="<%= produto.estoque_produto <= 5 ? 'low-stock' : '' %>">
                <td>#<%= produto.id_produto %></td>
                <td><%= produto.nome_produto %></td>
                <td><span class="badge"><%= produto.categoria_produto %></span></td>
                <td>R$ <%= parseFloat(produto.preco_produto).toFixed(2) %></td>
                <td>
                  <span class="stock-badge <%= produto.estoque_produto <= 5 ? 'critical' : '' %>">
                    <%= produto.estoque_produto %> un.
                  </span>
                </td>
                <td>
                  <a href="/admin/produtos/<%= produto.id_produto %>/editar" class="btn btn-tiny btn-info">
                    ✏️ Editar
                  </a>
                  <a href="/admin/produtos/<%= produto.id_produto %>/deletar" 
                     class="btn btn-tiny btn-danger"
                     onclick="return confirm('Tem certeza que deseja deletar este produto?')">
                    🗑️ Deletar
                  </a>
                </td>
              </tr>
            <% }); %>
          </tbody>
        </table>
      </section>
    <% } else { %>
      <section class="empty-state">
        <p>📭 Nenhum produto cadastrado ainda</p>
        <a href="/admin/produtos/novo" class="btn btn-primary">Criar Primeiro Produto</a>
      </section>
    <% } %>
  </main>
</section>

<%- include('../partials/footer') %>
