<!DOCTYPE html>
<html lang="pt-BR">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>adm</title>
  <link rel="stylesheet" href="/css/style.css">
  <link rel="stylesheet" href="/css/header.css">
  <link rel="stylesheet" href="/css/admin.css">
    <link rel="icon" href="/imagens/favicon2.png" type="image/png">
</head>

<section class="admin-wrapper">
  <aside class="admin-sidebar">
    <header class="admin-brand">
      <h2>⚙️ ADMIN</h2>
    </header>
    
    <nav class="admin-nav">
      <a href="/admin" class="nav-item">
        📊 Dashboard
      </a>
      <a href="/admin/usuarios" class="nav-item">
        👥 Usuários
      </a>
      <a href="/admin/diagnosticos" class="nav-item">
        📋 Diagnósticos
      </a>
      <a href="/admin/produtos" class="nav-item active">
        📦 Produtos
      </a>
      <a href="/admin-logout" class="nav-item nav-logout">
        🚪 Sair
      </a>
    </nav>
  </aside>
  
  <main class="admin-main">
    <header class="admin-header">
      <h1><%= isNovo ? '➕ Novo Produto' : '✏️ Editar Produto' %></h1>
    </header>
    
    <section class="form-container">
      <form method="POST" action="<%= isNovo ? '/admin/produtos' : '/admin/produtos/' + produto.id_produto %>" class="admin-form">
        <p class="form-group">
          <label for="nome">Nome do Produto *</label>
          <input 
            type="text" 
            id="nome" 
            name="nome" 
            value="<%= isNovo ? '' : produto.nome_produto %>"
            placeholder="Ex: Lâmpada Solar"
            required
          >
        </p>
        
        <p class="form-group">
          <label for="categoria">Categoria *</label>
          <select id="categoria" name="categoria" required>
            <option value="">Selecione uma categoria...</option>
            <option value="entrada" <%= !isNovo && produto.categoria_produto === 'entrada' ? 'selected' : '' %>>
              Entrada
            </option>
            <option value="medio" <%= !isNovo && produto.categoria_produto === 'medio' ? 'selected' : '' %>>
              Médio
            </option>
            <option value="avancado" <%= !isNovo && produto.categoria_produto === 'avancado' ? 'selected' : '' %>>
              Avançado
            </option>
          </select>
        </p>
        
        <p class="form-group">
          <label for="preco">Preço (R$) *</label>
          <input 
            type="number" 
            id="preco" 
            name="preco" 
            step="0.01"
            value="<%= isNovo ? '' : produto.preco_produto %>"
            placeholder="Ex: 89.90"
            required
          >
        </p>
        
        <p class="form-group">
          <label for="estoque">Estoque (unidades) *</label>
          <input 
            type="number" 
            id="estoque" 
            name="estoque" 
            value="<%= isNovo ? '' : produto.estoque_produto %>"
            placeholder="Ex: 10"
            required
          >
        </p>
        
        <p class="form-group">
          <label for="descricao">Descrição Detalhada *</label>
          <textarea 
            id="descricao" 
            name="descricao" 
            rows="6"
            placeholder="Descreva os detalhes do produto, especificações, benefícios, etc."
            required
          ><%= isNovo ? '' : produto.descricao %></textarea>
        </p>
        
        <footer class="form-actions">
          <button type="submit" class="btn btn-primary">
            <%= isNovo ? '✅ Criar Produto' : '✅ Salvar Alterações' %>
          </button>
          <a href="/admin/produtos" class="btn btn-secondary">
            ❌ Voltar
          </a>
        </footer>
      </form>
    </section>
  </main>
</section>

<%- include('../partials/footer') %>
