<!DOCTYPE html>
<html lang="pt-BR">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>adm</title>
  <link rel="stylesheet" href="/css/style.css">
  <link rel="stylesheet" href="/css/header.css">
  <link rel="stylesheet" href="/css/admin.css">
</head><%- include('../../views/partials/header') %>

<section class="admin-wrapper">
  <aside class="admin-sidebar">
    <header class="admin-brand">
      <h2>⚙️ ADMIN</h2>
    </header>
    
    <nav class="admin-nav">
      <a href="/admin" class="nav-item">
        📊 Dashboard
      </a>
      <a href="/admin/usuarios" class="nav-item">
        👥 Usuários
      </a>
      <a href="/admin/diagnosticos" class="nav-item active">
        📋 Diagnósticos
      </a>
      <a href="/admin/produtos" class="nav-item">
        📦 Produtos
      </a>
      <a href="/admin-logout" class="nav-item nav-logout">
        🚪 Sair
      </a>
    </nav>
  </aside>
  
  <main class="admin-main">
    <header class="admin-header">
      <h1>📋 Gerenciamento de Diagnósticos</h1>
      <p>Total de diagnósticos realizados: <strong><%= diagnosticos.length %></strong></p>
    </header>
    
    <% if (diagnosticos.length > 0) { %>
      <section class="table-container">
        <table class="admin-table">
          <thead>
            <tr>
              <th>ID</th>
              <th>Usuário</th>
              <th>Email</th>
              <th>Nível de Autonomia</th>
              <th>Data do Diagnóstico</th>
              <th>Ações</th>
            </tr>
          </thead>
          <tbody>
            <% diagnosticos.forEach(diag => { %>
              <tr>
                <td>#<%= diag.id %></td>
                <td><%= diag.nomeUsuario %></td>
                <td><%= diag.email %></td>
                <td>
                  <span class="badge badge-<%= diag.nivel %>">
                    <%= diag.nivel.charAt(0).toUpperCase() + diag.nivel.slice(1) %>
                  </span>
                </td>
                <td><%= diag.dataDiagnostico %></td>
                <td>
                  <a href="/admin/diagnosticos/deletar/<%= diag.id %>" 
                     class="btn btn-tiny btn-danger"
                     onclick="return confirm('Tem certeza que deseja deletar este diagnóstico?')">
                    🗑️ Deletar
                  </a>
                </td>
              </tr>
            <% }); %>
          </tbody>
        </table>
      </section>
    <% } else { %>
      <section class="empty-state">
        <p>📭 Nenhum diagnóstico realizado ainda</p>
        <a href="/diagnostico" class="btn btn-primary">Realizar Diagnóstico</a>
      </section>
    <% } %>
  </main>
</section>

<%- include('../../views/partials/footer') %>
