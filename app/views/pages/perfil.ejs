<!DOCTYPE html>
<html lang="pt-br">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>Meu Perfil — EcoGeneration</title>
  <link rel="stylesheet" href="/css/header.css">
  <link rel="stylesheet" href="/css/style.css">
  <link rel="stylesheet" href="/css/perfil.css">
  <link rel="icon" href="/imagens/favicon2.png" type="image/png">
</head>
<body>
  <%- include('../partials/header') %>

  <main class="perfil-container">

    <header class="perfil-header">
      <figure class="perfil-avatar">
        <span><%= usuario.nome_usuario.charAt(0).toUpperCase() %></span>
      </figure>
      <section class="perfil-info">
        <h1><%= usuario.nome_usuario %></h1>
        <p><%= usuario.email_usuario %></p>
      </section>
    </header>

    <!-- COMPRAS -->
    <section class="perfil-secao">
      <h2>Minhas Compras</h2>
      <% if (compras && compras.length > 0) { %>
        <ul class="compras-lista">
          <% compras.forEach(function(compra) { %>
            <li class="compra-item">
              <figure class="compra-item-img">
                <img src="/imagens/<%= compra.imagem_produto %>" alt="<%= compra.nome_produto %>">
              </figure>
              <section class="compra-item-info">
                <h3><%= compra.nome_produto %></h3>
                <p class="compra-item-preco">R$ <%= compra.preco_produto %></p>
                <p class="compra-item-status">
                  <span class="badge-confirmado"><%= compra.status_compra %></span>
                </p>
              </section>
              <section class="compra-item-id">
                <p>Pedido #<%= compra.id_compra %></p>
              </section>
            </li>
          <% }) %>
        </ul>
      <% } else { %>
        <p class="sem-itens">Você ainda não realizou nenhuma compra.</p>
        <a href="/ecoloja" class="btn-acao">Ir para a loja</a>
      <% } %>
    </section>

    <!-- DIAGNÓSTICOS -->
    <section class="perfil-secao">
      <h2>Meus Diagnósticos</h2>
      <% if (diagnosticos && diagnosticos.length > 0) { %>
        <ul class="diagnosticos-lista">
          <% diagnosticos.forEach(function(diag) { %>
            <li class="diagnostico-item">
              <section class="diagnostico-nivel <%= diag.nivel_autonomia %>">
                <strong>Autonomia <%= diag.nivel_autonomia %></strong>
              </section>
              <section class="diagnostico-detalhes">
                <p><strong>Frequência:</strong> <%= diag.frequencia %></p>
                <p><strong>Impacto:</strong> <%= diag.impacto %></p>
                <p><strong>Preparação:</strong> <%= diag.preparacao %></p>
                <p><strong>Prioridade:</strong> <%= diag.prioridade %></p>
                <p><strong>Tolerância:</strong> <%= diag.tolerancia %></p>
              </section>
              <footer class="diagnostico-acoes">
                <a href="/diagnostico" class="btn-refazer">Refazer diagnóstico</a>
              </footer>
            </li>
          <% }) %>
        </ul>
      <% } else { %>
        <p class="sem-itens">Você ainda não fez nenhum diagnóstico.</p>
        <a href="/diagnostico" class="btn-acao">Fazer diagnóstico agora</a>
      <% } %>
    </section>

    <!-- ZONA DE PERIGO -->
    <section class="perfil-secao perfil-perigo">
      <h2>Zona de Perigo</h2>
      <p>Ao excluir sua conta, todos os seus dados serão removidos permanentemente.</p>
      <button class="btn-excluir" id="btn-excluir-conta">Excluir minha conta</button>

      <section class="modal-confirmacao" id="modal-excluir" aria-hidden="true">
        <article class="modal-box">
          <h3>Tem certeza?</h3>
          <p>Esta ação não pode ser desfeita. Todos os seus dados serão excluídos.</p>
          <nav class="modal-acoes">
            <form action="/excluir-conta" method="POST">
              <button type="submit" class="btn-confirmar-excluir">Sim, excluir minha conta</button>
            </form>
            <button class="btn-cancelar" id="btn-cancelar-excluir">Cancelar</button>
          </nav>
        </article>
      </section>
    </section>

  </main>

  <%- include('../partials/footer') %>

  <script>
    const btnExcluir = document.getElementById('btn-excluir-conta');
    const modal = document.getElementById('modal-excluir');
    const btnCancelar = document.getElementById('btn-cancelar-excluir');

    btnExcluir.addEventListener('click', () => {
      modal.style.display = 'flex';
      modal.setAttribute('aria-hidden', 'false');
    });

    btnCancelar.addEventListener('click', () => {
      modal.style.display = 'none';
      modal.setAttribute('aria-hidden', 'true');
    });
  </script>
</body>
</html>
