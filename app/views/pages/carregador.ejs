    </tr>
  </table>

  <!-- Itens Relacionados -->
  <table width="90%" align="center" class="titulo-relacionados"><tr><td>Itens relacionados</td></tr></table>

  <table class="produtos-relacionados">
    <tr>
     <td class="produto-card">
        <img src="imagens/luminaria.png" alt="Luminária Solar LED" />
        <b>Luminária Solar LED</b>
        <span>R$ 199,99</span><br>
        <a href="luminaria-solar-led.html"><button>Ver Produto</button></a>
      </td>
      <td class="produto-card">
        <img src="imagens/kit.png" alt="Painel Solar 150W" />
        <b>kit solar</b>
        <span>R$ 399,90</span><br>
        <a href="painel-solar-150w.html"><button>Ver Produto</button></a>
      </td>
      <td class="produto-card">
        <img src="imagens/powerbankportatil.png" alt="powerbank" />
        <b>power bank</b>
        <span>R$ 89,90</span><br>
        <a href="garrafa-termica-1l.html"><button>Ver Produto</button></a>
      </td>
    </tr>
  </table>

  <!-- Rodapé -->
  <footer>© 2025 EcoGeneration</footer>

  <script src="/js/carregador.js" defer></script>
