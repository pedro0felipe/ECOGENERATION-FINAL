<!DOCTYPE html>
<html lang="pt-br">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1" />
  <title>| EcoGeneration</title>
  <link rel="stylesheet" href="/css/header.css" />
  <link rel="stylesheet" href="/css/carregador.css" />
  <link rel="apple-touch-icon" href="/imagens/favicon2.png">
  <link rel="icon" href="/imagens/favicon2.png" type="image/png">
</head>
<body>


  <!-- Cabeçalho -->
  <%- include("../partials/header") %>  

  <!-- Produto -->
  <table class="anuncio">
    <tr>
      <td width="40%">
        <img src="imagens/carregadoraluzsolar.png" alt="Lâmpada LED" class="produto" />
      </td>
      <td width="60%" class="info">
        <h2>Lâmpada LED</h2>
        <p>Iluminação eficiente com baixo consumo de energia.</p>
        <p><strong>Preço:</strong> <span class="preco">R$ 19,90</span></p>
        <p>Frete grátis | Vida útil longa</p>
         <ul>
          <li>Potência: 15W</li>
          <li>Temperatura de cor: 3000K</li>
          <li>Compatível com soquete E27</li>
        </ul>
         <section class="contador-quantidade" aria-label="Selecionar quantidade">
          <button type="button" id="btn-minus" aria-label="Diminuir quantidade">−</button>
          <input type="number" id="quantidade" name="quantidade" value="1" min="1" max="99" />
          <button type="button" id="btn-plus" aria-label="Aumentar quantidade">+</button>
        </section>
        <button class="comprar">Comprar agora</button>
