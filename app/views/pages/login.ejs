<!DOCTYPE html>
<html lang="pt-br">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1" />
  <title>ecogeneration</title>
  <!-- Semantic UI CDN -->
  
  <link rel="stylesheet" href="/css/header.css" >
  <link rel="stylesheet" href="/css/login.css" >
  <link rel="stylesheet" href="/css/style.css" >
  <link rel="apple-touch-icon" href="/imagens/favicon2.png">
  <link rel="icon" href="/imagens/favicon2.png" type="image/png">

  <!-- Open Graph (OG) — cartão de visitas nas redes sociais -->
  <meta property="og:locale" content="pt_BR">
  <meta property="og:type" content="website">
  <meta property="og:title" content="Entrar — EcoGeneration">
  <meta property="og:description" content="Acesse sua conta para ver seu histórico de diagnósticos e compras.">
  <meta property="og:url" content="https://ecogeneration-final-4hh3.onrender.com">
  <meta property="og:site_name" content="EcoGeneration">
  <meta property="og:image" content="https://ecogeneration-final-4hh3.onrender.com/imagens/faviconog.svg">
  <meta property="og:image:secure_url" content="https://ecogeneration-final-4hh3.onrender.com/imagens/faviconog.svg">
  <meta property="og:image:width" content="1200">
  <meta property="og:image:height" content="630">
  <meta property="og:image:alt" content="EcoGeneration — Autonomia Energética">
  <!-- Twitter/X Card -->
  <meta name="twitter:card" content="summary_large_image">
  <meta name="twitter:title" content="Entrar — EcoGeneration">
  <meta name="twitter:description" content="Acesse sua conta para ver seu histórico de diagnósticos e compras.">
  <meta name="twitter:image" content="https://ecogeneration-final-4hh3.onrender.com/imagens/faviconog.svg">
  <!-- PWA -->
  <link rel="manifest" href="/manifest.json">
  <meta name="theme-color" content="#2e7d32">
</head>
  <%- include("../partials/header") %>
<body class="layout">


  <main>
  
    <h1 class="ui header">Login</h1> 
    <form action="/login" method="post" class="ui form" id="login-form">
      <label for="email">E-mail</label>
      <input
        type="email"
        id="email"
        name="email"
        value="<%= old.email ? old.email : '' %>"
        placeholder="Digite seu e-mail"
      />
      <% if (errors.email) { %>
      <section class="ui pointing red basic label"><%= errors.email.msg %></section>
      <% } %>
      <% if (errors.geral) { %>
      <section class="ui pointing red basic label"><%= errors.geral.msg %></section>
      <% } %>

      <label for="senha">Senha</label>
      <input
        type="password"
        id="senha"
        name="senha"
        placeholder="Digite sua senha"
      />
      <% if (errors.senha) { %>
      <section class="ui pointing red basic label"><%= errors.senha.msg %></section>
      <% } %>

      <p>Ainda não tem uma conta? <a href="/cadastro">Cadastre-se aqui</a></p>

      <button class="ui primary button" type="submit">Enviar</button>
      <button class="ui button" type="reset">Limpar</button>
    </form>
  </main>

  <footer> 2025-Ecogeneration </footer>
  <script src="/js/validation.js"></script>
</body>
</html>