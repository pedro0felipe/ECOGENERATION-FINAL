<!DOCTYPE html>
<html lang="pt-br">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>EcoLoja — EcoGeneration</title>
  <link rel="stylesheet" href="/css/header.css">
  <link rel="stylesheet" href="/css/style.css">
  <link rel="stylesheet" href="/css/ecoloja.css">
  <link rel="apple-touch-icon" href="/imagens/favicon2.png">
  <link rel="icon" href="/imagens/favicon2.png" type="image/png">

  <!-- Open Graph (OG) — cartão de visitas nas redes sociais -->
  <meta property="og:locale" content="pt_BR">
  <meta property="og:type" content="website">
  <meta property="og:title" content="EcoLoja — Produtos de Energia Solar Portátil">
  <meta property="og:description" content="Lâmpadas, ventiladores, painéis e kits solares portáteis. Soluções para sua autonomia energética.">
  <meta property="og:url" content="https://ecogeneration-final-4hh3.onrender.com">
  <meta property="og:site_name" content="EcoGeneration">
  <meta property="og:image" content="https://ecogeneration-final-4hh3.onrender.com/imagens/GENERATIONN.svg">
  <meta property="og:image:secure_url" content="https://ecogeneration-final-4hh3.onrender.com/imagens/GENERATIONN.svg">
  <meta property="og:image:width" content="1200">
  <meta property="og:image:height" content="630">
  <meta property="og:image:alt" content="EcoGeneration — Autonomia Energética">
  <!-- Twitter/X Card -->
  <meta name="twitter:card" content="summary_large_image">
  <meta name="twitter:title" content="EcoLoja — Produtos de Energia Solar Portátil">
  <meta name="twitter:description" content="Lâmpadas, ventiladores, painéis e kits solares portáteis. Soluções para sua autonomia energética.">
  <meta name="twitter:image" content="https://ecogeneration-final-4hh3.onrender.com/imagens/GENERATIONN.svg">
  <!-- PWA -->
  <link rel="manifest" href="/manifest.json">
  <meta name="theme-color" content="#2e7d32">
</head>
<body>
  <%- include("../partials/header") %>

  <main class="ecoloja-container">

    <section class="ecoloja-header">
      <h1>Produtos em Destaque</h1>
      <p>Conheça nossas soluções mais populares</p>
    </section>

    <section class="produtos-grid" aria-label="Lista de produtos">
      <% if (produtos && produtos.length > 0) { %>
        <% produtos.forEach(function(produto) { %>
          <article class="produto-card">
            <header class="produto-categoria <%= produto.categoria_produto %>">
              <span><%= produto.categoria_produto === 'entrada' ? 'Entrada' : produto.categoria_produto === 'medio' ? 'Médio' : produto.categoria_produto === 'avancado' ? 'Avançado' : produto.categoria_produto %></span>
            </header>
            <% 
           
              switch (produto.categoria_produto) {
                case 'iluminacao':
                  imagemProduto = '/imagens/lampada.png';
                  break;
                case 'ventilacao':
                  imagemProduto = '/imagens/ventilador.png';
                  break;
                case 'energia':
                  imagemProduto = '/imagens/dobravel.png';
                  break;
                case 'kit':
                  imagemProduto = '/imagens/kit.png';
                  break;
                default:
                  imagemProduto = '/imagens/favicon2.png';
              }
            %>
            <figure class="produto-figura">
             <img src="/imagens/<%= produto.imagem_produto %>" alt="<%= produto.nome_produto %>" class="produto-img">
            </figure>
            <section class="produto-info">
              <h2 class="produto-nome"><%= produto.nome_produto %></h2>
              <p class="produto-desc"><%= produto.descricao_produto %></p>
              <footer class="produto-rodape">
                <strong class="produto-preco">R$ <%= produto.preco_produto %></strong>
                <a href="/produto/<%= produto.id_produto %>" class="btn-comprar">Ver produto</a>
              </footer>
            </section>
          </article>
        <% }) %>
      <% } else { %>
        <p class="sem-produtos">Nenhum produto encontrado.</p>
      <% } %>
    </section>

  </main>

  <%- include("../partials/footer") %>
</body>
</html>