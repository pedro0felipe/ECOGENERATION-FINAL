<!DOCTYPE html>
<html lang="pt-br">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>Resultado — EcoGeneration</title>
  <link rel="stylesheet" href="/css/header.css">
  <link rel="stylesheet" href="/css/style.css">
  <link rel="stylesheet" href="/css/resultado.css">
  <link rel="apple-touch-icon" href="/imagens/favicon2.png">
  <link rel="icon" href="/imagens/favicon2.png" type="image/png">

  <!-- Open Graph (OG) — cartão de visitas nas redes sociais -->
  <meta property="og:locale" content="pt_BR">
  <meta property="og:type" content="website">
  <meta property="og:title" content="Resultado do Diagnóstico — EcoGeneration">
  <meta property="og:description" content="Veja seu nível de autonomia energética e os produtos recomendados especialmente para você.">
  <meta property="og:url" content="https://ecogeneration-final-4hh3.onrender.com">
  <meta property="og:site_name" content="EcoGeneration">
  <meta property="og:image" content="https://ecogeneration-final-4hh3.onrender.com/imagens/faviconog.svg">
  <meta property="og:image:secure_url" content="https://ecogeneration-final-4hh3.onrender.com/imagens/faviconog.svg">
  <meta property="og:image:width" content="1200">
  <meta property="og:image:height" content="630">
  <meta property="og:image:alt" content="EcoGeneration — Autonomia Energética">
  <!-- Twitter/X Card -->
  <meta name="twitter:card" content="summary_large_image">
  <meta name="twitter:title" content="Resultado do Diagnóstico — EcoGeneration">
  <meta name="twitter:description" content="Veja seu nível de autonomia energética e os produtos recomendados especialmente para você.">
  <meta name="twitter:image" content="https://ecogeneration-final-4hh3.onrender.com/imagens/faviconog.svg">
  <!-- PWA -->
  <link rel="manifest" href="/manifest.json">
  <meta name="theme-color" content="#2e7d32">
</head>
<body>
  <%- include('../partials/header') %>

  <main class="resultado-container">

    <header class="resultado-header">
      <h1>Resultado do Diagnóstico</h1>
    </header>

    <% if (nivel === 'alta') { %>
      <section class="resultado alta">
        <h2>Autonomia Energética: Alta</h2>
        <p>Você está bem preparado para quedas de energia. Confira produtos avançados para maximizar sua autonomia.</p>
      </section>
    <% } else if (nivel === 'media') { %>
      <section class="resultado media">
        <h2>Autonomia Energética: Média</h2>
        <p>Você tem alguma preparação, mas ainda há espaço para melhorias. Veja nossas recomendações.</p>
      </section>
    <% } else { %>
      <section class="resultado baixa">
        <h2>Autonomia Energética: Baixa</h2>
        <p>Você depende fortemente da rede elétrica. Recomendamos começar com produtos acessíveis para aumentar sua autonomia.</p>
      </section>
    <% } %>

    <section class="recomendacoes" aria-label="Produtos recomendados">
      <h2>Produtos recomendados para você</h2>
      <section class="produtos-grid">
        <% produtosRecomendados.forEach(function(produto) { %>
          <article class="produto-card">
            <header class="produto-categoria">
              <span><%= produto.categoria_produto %></span>
            </header>
            <figure class="produto-figura">
              <img src="/imagens/<%= produto.imagem_produto %>" alt="<%= produto.nome_produto %>" class="produto-img">
            </figure>
            <section class="produto-info">
              <h3 class="produto-nome"><%= produto.nome_produto %></h3>
              <p class="produto-desc"><%= produto.descricao_produto %></p>
              <footer class="produto-rodape">
                <strong class="produto-preco">R$ <%= produto.preco_produto %></strong>
                <a href="/produto/<%= produto.id_produto %>" class="btn-comprar">Ver produto</a>
              </footer>
            </section>
          </article>
        <% }) %>
      </section>
    </section>

    <nav class="acoes">
      <a href="/diagnostico" class="btn-voltar">Refazer Diagnóstico</a>
      <a href="/ecoloja" class="btn-home">Ver toda a loja</a>
    </nav>

  </main>

  <%- include('../partials/footer') %>
</body>
</html>