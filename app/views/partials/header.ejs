<header>
  <section class="header-container">
    <figure class="logo-figure">
      <a href="/">
        <img src="/imagens/GENERATIONN.svg" alt="EcoGeneration Logo" class="logo">
      </a>
    </figure>

    <button class="hamburger" id="hamburger" aria-label="Abrir menu">
      <span></span><span></span><span></span>
    </button>

    <section class="header-actions">
      <nav class="nav-categorias" id="nav-categorias">
        <ul>
          <li class="<%= currentPath === '/ecoloja' ? 'active' : '' %>">
            <a href="/ecoloja">Loja</a>
          </li>
          <li class="<%= currentPath === '/diagnostico' ? 'active' : '' %>">
            <a href="/diagnostico">Diagnóstico</a>
          </li>
          <li class="<%= currentPath === '/sobre-nos' ? 'active' : '' %>">
            <a href="/sobre-nos">Sobre</a>
          </li>
          <% if (typeof usuarioLogado !== 'undefined' && usuarioLogado) { %>
            <li>
              <a href="/logout">Sair</a>
            </li>
          <% } else { %>        
            <li class="<%= currentPath === '/cadastro' ? 'active' : '' %>">
              <a href="/cadastro">Cadastrar</a>
            </li>
          <% } %>
        </ul>
      </nav>

      <div class="search-actions">
        <form action="/search" method="get" class="search-form">
          <input type="text" name="q" placeholder="Pesquisar..." />
          <button type="submit" class="search-btn" aria-label="Pesquisar">
            <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
              <circle cx="11" cy="11" r="8"></circle>
              <path d="m21 21-4.35-4.35"></path>
            </svg>
          </button>
        </form>
        <a href="<%= typeof usuarioLogado !== 'undefined' && usuarioLogado ? '/perfil' : '/login' %>" class="login-btn login-header-btn">
          <%= typeof usuarioLogado !== 'undefined' && usuarioLogado ? 'Olá, ' + (usuarioNome ? usuarioNome.split(' ')[0] : 'Usuário') : 'Entrar' %>
        </a>
      </div>
    </section>
  </section>
  
</header>

<script>
  document.addEventListener('DOMContentLoaded', () => {
    const hamburger = document.getElementById('hamburger');
    const navCategorias = document.getElementById('nav-categorias');
    if (!hamburger || !navCategorias) return;

    hamburger.addEventListener('click', () => {
      navCategorias.classList.toggle('open');
      hamburger.classList.toggle('open');
    });

    document.querySelectorAll('#nav-categorias a').forEach(link => {
      link.addEventListener('click', () => {
        navCategorias.classList.remove('open');
        hamburger.classList.remove('open');
      });
    });
  });
</script>